{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Java: Questions 2 + 3",
      "type": "java",
      "request": "launch",
      "mainClass": "com.project.Main",
      "projectName": "java-project",
      "cwd": "${workspaceFolder}/java-project",
      "vmArgs": "-Djava.library.path=${workspaceFolder}/cpp-project/build --enable-native-access=ALL-UNNAMED",
      "console": "integratedTerminal",
      "preLaunchTask": "cpp: build"
    },
    {
      "name": "Java: Question 4 (C++)",
      "type": "java",
      "request": "launch",
      "mainClass": "com.project.MainCpp",
      "projectName": "java-project",
      "cwd": "${workspaceFolder}/java-project",
      "vmArgs": "-Djava.library.path=${workspaceFolder}/cpp-project/build --enable-native-access=ALL-UNNAMED",
      "console": "integratedTerminal",
      "preLaunchTask": "cpp: build"
    }
  ]
}
